# Copy to .env and fill in values. Never commit .env.

# agent = ADK Runner picks URLs via tools (default); pipeline = enrich all then score
SCREENING_MODE=agent

GEMINI_API_KEY=
GEMINI_MODEL_ID=gemini-2.5-flash
# Vertex AI (optional): use GCP billing/quotas instead of AI Studio API key
# GEMINI_USE_VERTEXAI=true
# VERTEX_GCP_PROJECT_ID=your-company-vertex-project
# GCP_PROJECT_ID=exaai-sdk
# GCP_REGION=asia-south1
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\vertex-service-account.json
# SANDBOX_GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\exaai-sdk-service-account.json
# VERTEX_GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\vertex-service-account.json
# When GEMINI_USE_VERTEXAI=true, leave GEMINI_API_KEY empty (ADC auth only)
# Sandbox Cloud Run uses GCP_PROJECT_ID; Vertex uses VERTEX_GCP_PROJECT_ID when set

# LLM for agent + scoring: auto | gemini | groq | openrouter
# auto: Groq if GROQ_API_KEY set, else OpenRouter if OPEN_ROUTER_API_KEY set, else Gemini
LLM_PROVIDER=auto
GROQ_API_KEY=
GROQ_MODEL_ID=llama-3.1-8b-instant
GROQ_AGENT_MODEL_ID=llama-3.1-8b-instant
GROQ_FALLBACK_MODEL_IDS=llama-3.3-70b-versatile
GROQ_MAX_AGENT_TURNS=3
OPEN_ROUTER_API_KEY=
OPENROUTER_MODEL_ID=openrouter/free
OPENROUTER_AGENT_MODEL_ID=openai/gpt-oss-20b:free
OPENROUTER_FALLBACK_MODEL_IDS=openai/gpt-oss-20b:free
OPENROUTER_FREE_MAX_AGENT_TURNS=3
# false = heuristic JD parse (saves 1 Gemini call per /screen); true = LLM JD parse
JD_PARSE_USE_LLM=false
# 0 = most stable scores; overall score is derived from rubric match_scores (5-point steps)
LLM_TEMPERATURE=0
SCORING_SCORE_STEP=5
SCORING_RUBRIC_DERIVED=true
EXA_API_KEY=
GITHUB_TOKEN=
GITHUB_CLONE_ANALYSIS_ENABLED=false
SANDBOX_PROVIDER=cloud_run
SANDBOX_MAX_REPOS=12
SANDBOX_MAX_RESUME_REPOS=12
SANDBOX_MAX_PROFILE_REPOS=2
SANDBOX_TIMEOUT_SECONDS=300
SANDBOX_WAIT_SECONDS=45
SANDBOX_POLL_INTERVAL_SECONDS=2.0
# false = wait for sandbox before scoring (recommended); true = provisional 202 + poll
SANDBOX_DEFERRED_ENABLED=false
# true = run sandbox in parallel with Gemini; await reports at submit/score (requires deferred=false)
SANDBOX_OVERLAP_ENABLED=false
# true = agent/scorer judges sandbox (vulns/secrets); false = legacy deterministic penalties
SANDBOX_LLM_SCORING_ENABLED=true
# true = agent calls get_github_repo_structures + run_sandbox_analysis (agent mode only)
AGENT_EVIDENCE_ORCHESTRATION_ENABLED=true
# auto = no pre-run when orchestration on; risk_only = vuln scan pre-pass; full = heuristic pre-run
SANDBOX_PRE_RUN_MODE=auto
SANDBOX_FOCUS_MAX_FILES=12
SANDBOX_TOP_FILES_COUNT=5
SANDBOX_NETWORK_MODE=install_only
GCP_PROJECT_ID= exaai-sdk
GCP_REGION=asia-south1
CLOUD_RUN_SANDBOX_JOB_NAME=repo-evaluator
SANDBOX_REPORT_BUCKET=exaai-sdk-manav-reports
SANDBOX_REPORT_PREFIX=sandbox-reports
API_KEYS=dev-local-key-change-me

# Only crawl URLs explicitly on the resume (recommended). Set true to guess profile URLs.
INFER_PROFILE_URLS=false
# Pre-fetch resume profile URLs via Exa before agent scoring (populates sources_crawled)
AUTO_ENRICH_PROFILES=true
# strict = omit untrusted/limited crawl text from judge; balanced = limited includes warning + body
PROFILE_SCORING_MODE=strict

MAX_AGENT_TURNS=8
# Base agent wall-clock timeout; auto-extended when AGENT_EVIDENCE_ORCHESTRATION_ENABLED=true
AGENT_RUN_TIMEOUT_SECONDS=120
MAX_URLS_PER_RESUME=10
URL_FETCH_TIMEOUT_SECONDS=5
CONTENT_TOKEN_CAP=8000
CACHE_TTL_SECONDS=86400
URL_CACHE_PATH=./data/url_cache.db

AGENT_VERSION=0.1.0
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8080
