# Copy to .env and fill in values. Never commit .env.

# agent = ADK Runner picks URLs via tools (default); pipeline = enrich all then score
SCREENING_MODE=agent

GEMINI_API_KEY=
GEMINI_MODEL_ID=gemini-2.5-flash

# LLM for agent + scoring: auto | gemini | openrouter
# auto uses OpenRouter when OPEN_ROUTER_API_KEY is set, otherwise Gemini
LLM_PROVIDER=auto
OPEN_ROUTER_API_KEY=
OPENROUTER_MODEL_ID=openrouter/free
OPENROUTER_AGENT_MODEL_ID=openai/gpt-oss-20b:free
OPENROUTER_FALLBACK_MODEL_IDS=openai/gpt-oss-20b:free
OPENROUTER_FREE_MAX_AGENT_TURNS=3
# false = heuristic JD parse (saves 1 Gemini call per /screen); true = LLM JD parse
JD_PARSE_USE_LLM=false
EXA_API_KEY=
GITHUB_TOKEN=
GITHUB_CLONE_ANALYSIS_ENABLED=false
SANDBOX_PROVIDER=cloud_run
SANDBOX_MAX_REPOS=2
SANDBOX_MAX_RESUME_REPOS=5
SANDBOX_MAX_PROFILE_REPOS=2
SANDBOX_TIMEOUT_SECONDS=300
SANDBOX_WAIT_SECONDS=45
SANDBOX_POLL_INTERVAL_SECONDS=2.0
SANDBOX_NETWORK_MODE=install_only
GCP_PROJECT_ID= exaai-sdk
GCP_REGION=asia-south1
CLOUD_RUN_SANDBOX_JOB_NAME=repo-evaluator
SANDBOX_REPORT_BUCKET=exaai-sdk-manav-reports
SANDBOX_REPORT_PREFIX=sandbox-reports
API_KEYS=dev-local-key-change-me

# Only crawl URLs explicitly on the resume (recommended). Set true to guess profile URLs.
INFER_PROFILE_URLS=false
# strict = omit untrusted/limited crawl text from judge; balanced = limited includes warning + body
PROFILE_SCORING_MODE=strict

MAX_AGENT_TURNS=8
AGENT_RUN_TIMEOUT_SECONDS=120
MAX_URLS_PER_RESUME=10
URL_FETCH_TIMEOUT_SECONDS=5
CONTENT_TOKEN_CAP=8000
CACHE_TTL_SECONDS=86400
URL_CACHE_PATH=./data/url_cache.db

AGENT_VERSION=0.1.0
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8080
