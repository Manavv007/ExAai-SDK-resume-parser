# Copy to .env and fill in values. Never commit .env.

GEMINI_API_KEY=
GEMINI_MODEL_ID=gemini-2.5-flash
EXA_API_KEY=
API_KEYS=dev-local-key-change-me

# Only crawl URLs explicitly on the resume (recommended). Set true to guess profile URLs.
INFER_PROFILE_URLS=false
# strict = omit untrusted/limited crawl text from judge; balanced = limited includes warning + body
PROFILE_SCORING_MODE=strict

MAX_URLS_PER_RESUME=10
URL_FETCH_TIMEOUT_SECONDS=5
CONTENT_TOKEN_CAP=8000
CACHE_TTL_SECONDS=86400
URL_CACHE_PATH=./data/url_cache.db

AGENT_VERSION=0.1.0
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8080
